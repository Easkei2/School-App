        let totalPaid = 0, totalDue = 0;
        if (currentUser.role !== 'teacher') {
            totalPaid = db.studentLedgers.filter(l => l.year === getCurrentYear()).reduce((s,l)=>s+l.paidAmount,0);
            totalDue = db.studentLedgers.filter(l => l.year === getCurrentYear()).reduce((s,l)=>s+l.dueAmount,0);
        } else {
            const studentIds = students.map(s=>s.studentId);
            totalPaid = db.studentLedgers.filter(l => studentIds.includes(l.studentId) && l.year === getCurrentYear()).reduce((s,l)=>s+l.paidAmount,0);
            totalDue = db.studentLedgers.filter(l => studentIds.includes(l.studentId) && l.year === getCurrentYear()).reduce((s,l)=>s+l.dueAmount,0);
        }
        const totalExams = db.examResults.filter(r => students.some(s=>s.studentId===r.studentId)).length;
        const totalAttendance = db.attendance.filter(a => students.some(s=>s.studentId===a.studentId)).length;
        contai
