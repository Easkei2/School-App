<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Maamba Walter Olsen Academy | SPCK Edition</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: linear-gradient(145deg, #f0f4fc 0%, #e4ebf5 100%); min-height: 100vh; padding: 24px 20px; }
        .app-container { max-width: 1440px; margin: 0 auto; }
        .header { background: rgba(255,255,255,0.92); backdrop-filter: blur(8px); border-radius: 40px; padding: 12px 28px; margin-bottom: 28px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); }
        .logo-area { display: flex; align-items: center; gap: 16px; cursor: pointer; }
        .school-logo { width: 60px; height: 60px; border-radius: 30px; object-fit: cover; background: #e2e8f0; border: 2px solid white; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .logo-text h1 { font-size: 1.5rem; background: linear-gradient(135deg, #1e3c72, #2a5298, #1e6f5c); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .logo-text p { font-size: 0.7rem; color: #4b6b8f; }
        .user-info { display: flex; align-items: center; gap: 12px; background: #f1f5f9; padding: 6px 18px; border-radius: 60px; }
        .logout-btn, .change-pwd-btn { background: #1e3a5f; color: white; border: none; padding: 6px 16px; border-radius: 40px; cursor: pointer; font-weight: 500; transition: 0.2s; }
        .change-pwd-btn { background: #f59e0b; }
        .tabs { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 32px; justify-content: center; }
        .tab-btn { background: rgba(255,255,255,0.7); backdrop-filter: blur(4px); border: none; padding: 10px 28px; border-radius: 60px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: 0.2s; color: #2c3e66; margin: 0; }
        .tab-btn.active { background: #1e3a5f; color: white; box-shadow: 0 8px 20px -6px rgba(30,58,95,0.4); transform: scale(1.02); }
        .card { background: white; border-radius: 32px; padding: 28px; margin-bottom: 28px; box-shadow: 0 20px 35px -12px rgba(0,0,0,0.08); }
        .card h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 24px; border-left: 5px solid #2c6e9e; padding-left: 18px; display: flex; justify-content: space-between; flex-wrap: wrap; align-items: center; gap: 12px; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; margin-bottom: 28px; }
        .stat-card { background: linear-gradient(145deg, #ffffff, #f8fafc); border-radius: 28px; padding: 20px; text-align: center; transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-4px); }
        .stat-card i { font-size: 2.2rem; color: #1e3a5f; margin-bottom: 12px; }
        .stat-card h3 { font-size: 2rem; font-weight: 800; }
        .filter-bar { background: #f8fafc; border-radius: 60px; padding: 12px 24px; margin-bottom: 24px; display: flex; flex-wrap: wrap; gap: 16px; align-items: center; border: 1px solid #e2e8f0; }
        .filter-bar label { font-weight: 600; color: #2c3e66; }
        select, input { padding: 8px 18px; border-radius: 40px; border: 1px solid #cbd5e1; background: white; font-size: 0.85rem; }
        .btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 16px; border-radius: 40px; font-size: 0.75rem; font-weight: 600; cursor: pointer; border: none; transition: 0.2s; }
        .btn-primary { background: #1e3a5f; color: white; }
        .btn-edit { background: #f59e0b; color: white; }
        .btn-delete { background: #dc2626; color: white; }
        .btn-success { background: #10b981; color: white; }
        .photo-thumb { width: 50px; height: 50px; border-radius: 50%; object-fit: cover; background: #e2e8f0; cursor: pointer; }
        .table-wrapper { overflow-x: auto; border-radius: 24px; }
        th, td { padding: 14px 12px; text-align: left; border-bottom: 1px solid #e9edf2; vertical-align: middle; }
        th { background: #f8fafd; font-weight: 600; color: #1e3a5f; }
        footer { text-align: center; margin-top: 40px; font-size: 0.75rem; color: #5b6e8c; font-weight: 500; letter-spacing: 0.5px; }
        @media (max-width: 700px) { .tab-btn { padding: 6px 18px; font-size: 0.75rem; } }
        .sub-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
        .sub-tab-btn { background: #f1f5f9; border: none; padding: 6px 16px; border-radius: 40px; font-size: 0.8rem; cursor: pointer; }
        .sub-tab-btn.active { background: #1e3a5f; color: white; }
        .ledger-entry { background: #f8fafc; padding: 8px 12px; border-radius: 12px; margin: 4px 0; font-size: 0.85rem; }
        .login-container { max-width: 400px; margin: 80px auto; background: white; border-radius: 48px; padding: 40px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }
        .login-container input { width: 100%; padding: 14px; margin-bottom: 16px; border-radius: 60px; border: 1px solid #cbd5e1; }
        .login-container button { width: 100%; padding: 14px; background: #1e3a5f; color: white; border: none; border-radius: 60px; font-weight: 600; cursor: pointer; }
        .login-error { color: #dc2626; margin-top: 12px; text-align: center; }
    </style>
</head>
<body>
<div id="root"></div>

<script>
    // ================================================================
    //  SCHOOL MANAGEMENT SYSTEM – LOCAL STORAGE VERSION (SPCK)
    //  All data stored in localStorage, no external backend.
    //  Default login: manager / Admin@123
    // ================================================================

    // ---------- GLOBAL STATE ----------
    let currentUser = null;       // { id, username, role, classId, name }
    let currentTab = 'dashboard';
    let schoolLogoBase64 = null;
    let db = {};                 // will hold all school data
    let accountingView = 'dashboard';

    // ---------- HELPERS ----------
    function getCurrentYear() { return new Date().getFullYear(); }
    function getCurrentTerm() { const m = new Date().getMonth(); if (m<4) return 'Term 1'; if (m<8) return 'Term 2'; return 'Term 3'; }
    function nextId(arr, key) { return arr.length ? Math.max(...arr.map(i=>i[key])) + 1 : 1; }
    function calculateGrade(score) { if (score>=80) return 'A'; if (score>=70) return 'B'; if (score>=60) return 'C'; if (score>=50) return 'D'; return 'F'; }
    function getClassName(id) { const c = db.classes?.find(c=>c.classId===id); return c ? c.className : '-'; }
    function getAccountName(id) { const a = db.accounts?.find(a=>a.accountId===id); return a ? a.name : 'Unknown'; }

    // ---------- PERSISTENCE (localStorage) ----------
    function saveSchoolData() {
        localStorage.setItem('mwoa_school_data', JSON.stringify(db));
    }

    function loadSchoolData() {
        const stored = localStorage.getItem('mwoa_school_data');
        if (stored) {
            db = JSON.parse(stored);
        } else {
            initDemoData();
            saveSchoolData();
        }
        // Ensure arrays exist
        if (!db.receiptBooks) db.receiptBooks = [];
        if (!db.receiptCancellations) db.receiptCancellations = [];
        if (!db.users) db.users = [];
        if (!db.accounts) db.accounts = [];
        if (!db.transactions) db.transactions = [];
        if (!db.bankStatements) db.bankStatements = [];

        // Seed default accounts if empty
        if (db.accounts.length === 0) {
            db.accounts = [
                { accountId: 1, name: 'Cash', type: 'asset', balance: 0 },
                { accountId: 2, name: 'Bank', type: 'asset', balance: 0 },
                { accountId: 3, name: 'School Fees Income', type: 'income' },
                { accountId: 4, name: 'Other Income', type: 'income' },
                { accountId: 5, name: 'Salaries Expense', type: 'expense' },
                { accountId: 6, name: 'Utilities Expense', type: 'expense' },
                { accountId: 7, name: 'Supplies Expense', type: 'expense' },
                { accountId: 8, name: 'Maintenance Expense', type: 'expense' }
            ];
            saveSchoolData();
        }

        // Ensure default manager user exists
        if (!db.users.some(u => u.username === 'manager')) {
            db.users.push({ id: 1, username: 'manager', passwordHash: btoa('Admin@123'), role: 'manager', classId: null, name: 'School Manager' });
            saveSchoolData();
        }
    }

    function initDemoData() {
        const currYear = getCurrentYear();
        db.classes = [
            { classId: 1, className: 'Grade 1', roomNumber: '101' },
            { classId: 2, className: 'Grade 2', roomNumber: '102' },
            { classId: 3, className: 'Grade 3', roomNumber: '103' }
        ];
        db.subjects = [
            { subjectId: 1, subjectName: 'Mathematics', description: 'Core math' },
            { subjectId: 2, subjectName: 'English', description: 'Language & literature' },
            { subjectId: 3, subjectName: 'Science', description: 'Basic sciences' }
        ];
        db.parents = [
            { parentId: 1, firstName: 'John', lastName: 'Mwila', phone: '0977123456', email: 'john@ex.com', address: 'Lusaka' },
            { parentId: 2, firstName: 'Grace', lastName: 'Banda', phone: '0966112233', email: 'grace@ex.com', address: 'Kitwe' },
            { parentId: 3, firstName: 'Peter', lastName: 'Zulu', phone: '0977555444', email: 'peter@ex.com', address: 'Ndola' }
        ];
        db.teachers = [
            { teacherId: 1, firstName: 'Alice', lastName: 'Phiri', phone: '0977555444', email: 'alice@sch.com', subjectId: 1, classId: 1, photo: null },
            { teacherId: 2, firstName: 'Brian', lastName: 'Mbewe', phone: '0966333222', email: 'brian@sch.com', subjectId: 2, classId: 2, photo: null },
            { teacherId: 3, firstName: 'Cynthia', lastName: 'Zulu', phone: '0977888999', email: 'cynthia@sch.com', subjectId: 3, classId: 3, photo: null }
        ];
        db.students = [
            { studentId: 1, firstName: 'James', lastName: 'Mwila', dateOfBirth: '2015-03-12', gender: 'Male', classId: 1, parentId: 1, photo: null },
            { studentId: 2, firstName: 'Mary', lastName: 'Banda', dateOfBirth: '2014-07-22', gender: 'Female', classId: 2, parentId: 2, photo: null },
            { studentId: 3, firstName: 'Liam', lastName: 'Zulu', dateOfBirth: '2013-11-05', gender: 'Male', classId: 3, parentId: 3, photo: null }
        ];
        const terms = ['Term 1', 'Term 2', 'Term 3'];
        const amounts = { 1: 500, 2: 550, 3: 600 };
        let fid = 1;
        db.feeStructures = [];
        for (let classId of [1,2,3]) for (let term of terms) db.feeStructures.push({ feeStructId: fid++, classId, year: currYear, term, amount: amounts[classId] });
        let lid = 1;
        db.studentLedgers = [];
        for (let student of db.students) {
            for (let fs of db.feeStructures.filter(fs => fs.classId === student.classId && fs.year === currYear)) {
                db.studentLedgers.push({ ledgerId: lid++, studentId: student.studentId, year: fs.year, term: fs.term, dueAmount: fs.amount, paidAmount: 0, balance: fs.amount, payments: [] });
            }
        }
        db.examResults = [];
        const today = new Date().toISOString().slice(0,10);
        db.attendance = [
            { attendanceId: 1, studentId: 1, date: today, status: 'Present', term: getCurrentTerm(), year: currYear },
            { attendanceId: 2, studentId: 2, date: today, status: 'Absent', term: getCurrentTerm(), year: currYear },
            { attendanceId: 3, studentId: 3, date: today, status: 'Late', term: getCurrentTerm(), year: currYear }
        ];
        db.receiptBooks = [];
        db.receiptCancellations = [];
        db.users = [];
        db.accounts = [];
        db.transactions = [];
        db.bankStatements = [];
        // users will be added on load if missing
    }

    // ---------- LOGO & PHOTO UPLOADS ----------
    function loadLogo() {
        const stored = localStorage.getItem('mwoa_school_logo');
        if (stored) {
            schoolLogoBase64 = stored;
            document.getElementById('schoolLogo').src = stored;
        }
    }
    function saveLogo(base64) {
        schoolLogoBase64 = base64;
        localStorage.setItem('mwoa_school_logo', base64);
        document.getElementById('schoolLogo').src = base64;
    }
    function uploadLogo() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.onchange = (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (ev) => saveLogo(ev.target.result);
                reader.readAsDataURL(file);
            }
        };
        input.click();
    }
    function uploadPhoto(callback) {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/*';
        input.onchange = (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (ev) => callback(ev.target.result);
                reader.readAsDataURL(file);
            }
        };
        input.click();
    }
    function uploadFile(callback, accept = '.pdf,.png,.jpg,.jpeg') {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = accept;
        input.onchange = (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (ev) => callback(ev.target.result, file.name);
                reader.readAsDataURL(file);
            }
        };
        input.click();
    }

    // ---------- RECEIPT HELPER ----------
    function getNextReceiptNumber(bookId) {
        const book = db.receiptBooks.find(b => b.bookId === bookId);
        if (!book) return null;
        const usedNumbers = [];
        db.studentLedgers.forEach(ledger => {
            ledger.payments.forEach(p => { if (p.receiptBookId === bookId) usedNumbers.push(parseInt(p.receiptNumber)); });
        });
        db.receiptCancellations.forEach(c => { if (c.bookId === bookId) usedNumbers.push(parseInt(c.receiptNumber)); });
        for (let i = book.startNumber; i <= book.endNumber; i++) {
            if (!usedNumbers.includes(i)) return i;
        }
        return null;
    }

    // ---------- USER MANAGEMENT ----------
    function hashPassword(pwd) { return btoa(pwd); }
    function verifyPassword(pwd, hash) { return btoa(pwd) === hash; }

    // ---------- LOGIN / LOGOUT ----------
    function handleLogin(username, password) {
        const user = db.users.find(u => u.username === username && verifyPassword(password, u.passwordHash));
        if (user) {
            currentUser = user;
            renderApp();
        } else {
            document.getElementById('loginError').innerText = 'Invalid username or password';
        }
    }

    function logout() {
        currentUser = null;
        showLoginScreen();
    }

    function changePassword() {
        const newPwd = prompt('Enter new password (min 6 characters):');
        if (newPwd && newPwd.length >= 6) {
            currentUser.passwordHash = hashPassword(newPwd);
            const idx = db.users.findIndex(u => u.id === currentUser.id);
            if (idx !== -1) {
                db.users[idx].passwordHash = currentUser.passwordHash;
                saveSchoolData();
                alert('Password changed. Please log in again.');
                logout();
            }
        } else if (newPwd) alert('Password must be at least 6 characters.');
    }

    // ---------- RENDER FUNCTIONS ----------
    function renderTabs() {
        const tabsContainer = document.getElementById('tabs');
        if (!tabsContainer) return;
        let tabs = [];
        const isAdmin = currentUser.role === 'manager' || currentUser.role === 'secretary' || currentUser.role === 'accountant';
        if (isAdmin) {
            tabs = ['dashboard', 'parents', 'classes', 'subjects', 'teachers', 'students', 'feeStructures', 'payFees', 'examResults', 'attendance', 'receiptBooks', 'accounting', 'users'];
        } else {
            tabs = ['dashboard', 'students', 'examResults', 'attendance'];
        }
        tabsContainer.innerHTML = tabs.map(tab => {
            let icon = { dashboard:'📊', parents:'👪', classes:'🏫', subjects:'📚', teachers:'👩‍🏫', students:'🎓', feeStructures:'💰', payFees:'💵', examResults:'📝', attendance:'📋', receiptBooks:'📒', accounting:'🧾', users:'👥' }[tab] || '📌';
            return `<button class="tab-btn ${currentTab === tab ? 'active' : ''}" data-tab="${tab}">${icon} ${tab.charAt(0).toUpperCase()+tab.slice(1)}</button>`;
        }).join('');
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                currentTab = btn.getAttribute('data-tab');
                if (currentTab === 'accounting') accountingView = 'dashboard';
                renderTabs();
                renderContent();
            });
        });
    }

    function renderContent() {
        const container = document.getElementById('content');
        if (!container) return;
        loadSchoolData(); // ensure latest data
        switch (currentTab) {
            case 'dashboard': renderDashboard(container); break;
            case 'parents': renderParents(container); break;
            case 'classes': renderClasses(container); break;
            case 'subjects': renderSubjects(container); break;
            case 'teachers': renderTeachers(container); break;
            case 'students': renderStudents(container); break;
            case 'feeStructures': renderFeeStructures(container); break;
            case 'payFees': renderPayFees(container); break;
            case 'examResults': renderExamResults(container); break;
            case 'attendance': renderAttendance(container); break;
            case 'receiptBooks': renderReceiptBooks(container); break;
            case 'accounting': renderAccounting(container); break;
            case 'users': renderUsers(container); break;
            default: container.innerHTML = '<div class="card"><p>Page not found.</p></div>';
        }
        attachGlobalListeners();
    }

    // ----- DASHBOARD -----
